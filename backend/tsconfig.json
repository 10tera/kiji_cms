{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["@cloudflare/workers-types"]
  },
  "include": ["src/**/*.ts", "../db/**/*.ts", "../worker-configuration.d.ts", "../cloudflare-env.d.ts"],
  "exclude": ["node_modules"]
}
